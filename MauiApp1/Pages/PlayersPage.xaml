<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.Pages.PlayersPage"
             Title="Players">

    <ContentPage.Resources>
        <Style TargetType="Entry">
            <Setter Property="TextColor" Value="#0F172A" />
            <Setter Property="PlaceholderColor" Value="#64748B" />
            <Setter Property="BackgroundColor" Value="#FFFFFF" />
        </Style>
    </ContentPage.Resources>

    <ContentPage.BackgroundColor>#F1F5F9</ContentPage.BackgroundColor>

    <Grid Padding="16" RowDefinitions="Auto,*" ColumnDefinitions="1.1*,1*" ColumnSpacing="12">
        <Grid Grid.Row="0" Grid.ColumnSpan="2" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
            <Entry Grid.Column="0" Placeholder="Search player" Text="{Binding SearchText}" TextChanged="OnSearchChanged" />
            <Button Grid.Column="1" Text="Refresh" BackgroundColor="#2563EB" TextColor="White" Clicked="OnRefreshClicked" />
        </Grid>

        <Border Grid.Row="1" Grid.Column="0" Stroke="#CBD5E1" StrokeThickness="1" BackgroundColor="White" Padding="12" StrokeShape="RoundRectangle 12">
            <VerticalStackLayout Spacing="8">
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Entry Grid.Column="0" Placeholder="Team Id" Keyboard="Numeric" Text="{Binding PlayerTeamIdInput}" />
                    <Entry Grid.Column="1" Placeholder="Jersey #" Keyboard="Numeric" Text="{Binding PlayerJerseyInput}" />
                </Grid>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Entry Grid.Column="0" Placeholder="First Name" Text="{Binding PlayerFirstNameInput}" />
                    <Entry Grid.Column="1" Placeholder="Last Name" Text="{Binding PlayerLastNameInput}" />
                </Grid>

                <Entry Placeholder="Position" Text="{Binding PlayerPositionInput}" />

                <Label Text="{Binding SelectedPlayerIdLabel}" FontSize="12" TextColor="#475569" />

                <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="6">
                    <Button Grid.Column="0" Text="Create" Clicked="OnCreatePlayerClicked" BackgroundColor="#16A34A" TextColor="White" />
                    <Button Grid.Column="1" Text="Update" Clicked="OnUpdatePlayerClicked" BackgroundColor="#F59E0B" TextColor="White" />
                    <Button Grid.Column="2" Text="Delete" Clicked="OnDeletePlayerClicked" BackgroundColor="#DC2626" TextColor="White" />
                    <Button Grid.Column="3" Text="Clear" Clicked="OnClearPlayerClicked" BackgroundColor="#475569" TextColor="White" />
                </Grid>

                <CollectionView ItemsSource="{Binding FilteredPlayers}"
                                SelectionMode="Single"
                                SelectionChanged="OnPlayerSelectionChanged">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Stroke="#E2E8F0" StrokeThickness="1" BackgroundColor="White" Padding="10" Margin="0,0,0,6" StrokeShape="RoundRectangle 9">
                                <VerticalStackLayout>
                                    <Label Text="{Binding FullName}" FontAttributes="Bold" TextColor="#0F172A" />
                                    <Label Text="{Binding TeamDisplay}" FontSize="12" TextColor="#475569" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Stroke="#CBD5E1" StrokeThickness="1" BackgroundColor="White" Padding="12" StrokeShape="RoundRectangle 12">
            <ScrollView>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Player Profile" FontSize="22" FontAttributes="Bold" TextColor="#0F172A" />
                    <Label Text="{Binding SelectedPlayerName}" TextColor="#334155" />
                    <Label Text="{Binding SelectedPlayerTeam}" TextColor="#334155" />
                    <Label Text="{Binding SelectedPlayerPosition}" TextColor="#334155" />

                    <Label Text="Stats" FontSize="18" FontAttributes="Bold" TextColor="#0F172A" Margin="0,8,0,0" />
                    <Label Text="{Binding StatPPG}" TextColor="#475569" />
                    <Label Text="{Binding StatAssists}" TextColor="#475569" />
                    <Label Text="{Binding StatRebounds}" TextColor="#475569" />
                    <Label Text="{Binding StatSteals}" TextColor="#475569" />

                </VerticalStackLayout>
            </ScrollView>
        </Border>
    </Grid>

</ContentPage>
