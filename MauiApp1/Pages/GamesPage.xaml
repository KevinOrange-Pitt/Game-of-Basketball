<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:MauiApp1.Controls"
             x:Class="MauiApp1.Pages.GamesPage"
             Shell.TabBarIsVisible="False"
             Title="Games">

    <ContentPage.Resources>
        <Style TargetType="Entry">
            <Setter Property="TextColor" Value="#0F172A" />
            <Setter Property="PlaceholderColor" Value="#64748B" />
            <Setter Property="BackgroundColor" Value="#FFFFFF" />
        </Style>
    </ContentPage.Resources>

    <ContentPage.BackgroundColor>#F1F5F9</ContentPage.BackgroundColor>

    <Grid RowDefinitions="*,Auto">
    <Grid Grid.Row="0" Padding="16" RowDefinitions="Auto,*" ColumnDefinitions="1.1*,1*" ColumnSpacing="12">
        <Grid Grid.Row="0" Grid.ColumnSpan="2" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
            <Label Grid.Column="0" Text="Games" FontSize="30" FontAttributes="Bold" TextColor="#0F172A" />
            <Button Grid.Column="1" Text="Refresh" Clicked="OnRefreshClicked" BackgroundColor="#2563EB" TextColor="White" />
        </Grid>

        <Border Grid.Row="1" Grid.Column="0" Stroke="#CBD5E1" StrokeThickness="1" BackgroundColor="White" Padding="12" StrokeShape="RoundRectangle 12">
            <VerticalStackLayout Spacing="8">
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Picker Grid.Column="0"
                            Title="Home Team"
                            ItemsSource="{Binding Teams}"
                            ItemDisplayBinding="{Binding Display}"
                            SelectedItem="{Binding SelectedHomeTeam}" />
                    <Picker Grid.Column="1"
                            Title="Away Team"
                            ItemsSource="{Binding Teams}"
                            ItemDisplayBinding="{Binding Display}"
                            SelectedItem="{Binding SelectedAwayTeam}" />
                </Grid>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Border Grid.Column="0" Stroke="#E2E8F0" StrokeThickness="1" BackgroundColor="#F8FAFC" Padding="8" StrokeShape="RoundRectangle 8">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="{Binding SelectedHomeTeamNameDisplay}" TextColor="#0F172A" FontAttributes="Bold" FontSize="12" />
                            <Label Text="{Binding SelectedHomeTeamIdDisplay}" TextColor="#64748B" FontSize="11" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" Stroke="#E2E8F0" StrokeThickness="1" BackgroundColor="#F8FAFC" Padding="8" StrokeShape="RoundRectangle 8">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="{Binding SelectedAwayTeamNameDisplay}" TextColor="#0F172A" FontAttributes="Bold" FontSize="12" />
                            <Label Text="{Binding SelectedAwayTeamIdDisplay}" TextColor="#64748B" FontSize="11" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Entry Grid.Column="0" Placeholder="Home Team Id" Keyboard="Numeric" Text="{Binding GameHomeTeamIdInput}" />
                    <Entry Grid.Column="1" Placeholder="Away Team Id" Keyboard="Numeric" Text="{Binding GameAwayTeamIdInput}" />
                </Grid>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Entry Grid.Column="0" Placeholder="Game Date (yyyy-MM-dd HH:mm)" Text="{Binding GameDateInput}" />
                    <Entry Grid.Column="1" Placeholder="Location" Text="{Binding GameLocationInput}" />
                </Grid>

                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                    <Entry Grid.Column="0" Placeholder="Home Score" Keyboard="Numeric" Text="{Binding GameHomeScoreInput}" />
                    <Entry Grid.Column="1" Placeholder="Away Score" Keyboard="Numeric" Text="{Binding GameAwayScoreInput}" />
                    <Entry Grid.Column="2" Placeholder="Status (try Scheduled)" Text="{Binding GameStatusInput}" />
                </Grid>

                <Label Text="{Binding SelectedGameLabel}" FontSize="12" TextColor="#475569" />

                <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="6">
                    <Button Grid.Column="0" Text="Create" Clicked="OnCreateGameClicked" BackgroundColor="#16A34A" TextColor="White" />
                    <Button Grid.Column="1" Text="Update" Clicked="OnUpdateGameClicked" BackgroundColor="#F59E0B" TextColor="White" />
                    <Button Grid.Column="2" Text="Delete" Clicked="OnDeleteGameClicked" BackgroundColor="#DC2626" TextColor="White" />
                    <Button Grid.Column="3" Text="Clear" Clicked="OnClearGameClicked" BackgroundColor="#475569" TextColor="White" />
                </Grid>

                <Label Text="Known Teams" FontAttributes="Bold" TextColor="#334155" />
                <CollectionView ItemsSource="{Binding Teams}" HeightRequest="120">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Label Text="{Binding Display}" TextColor="#64748B" Margin="0,0,0,4" FontSize="12" />
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Stroke="#CBD5E1" StrokeThickness="1" BackgroundColor="White" Padding="12" StrokeShape="RoundRectangle 12">
            <VerticalStackLayout Spacing="8">
                <Label Text="Scheduled Games" FontSize="22" FontAttributes="Bold" TextColor="#0F172A" />

                <CollectionView ItemsSource="{Binding GameRows}"
                                SelectionMode="Single"
                                SelectionChanged="OnGameSelectionChanged">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Stroke="#E2E8F0" StrokeThickness="1" BackgroundColor="White" Padding="10" Margin="0,0,0,6" StrokeShape="RoundRectangle 9">
                                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
                                    <Label Grid.Row="0" Grid.Column="0" Text="{Binding MatchupText}" FontAttributes="Bold" TextColor="#0F172A" />
                                    <Label Grid.Row="0" Grid.Column="1" Text="{Binding GameId, StringFormat='Id {0}'}" TextColor="#64748B" FontSize="12" />
                                    <Label Grid.Row="1" Grid.Column="0" Text="{Binding DateText}" TextColor="#475569" FontSize="12" />
                                    <Label Grid.Row="1" Grid.Column="1" Text="{Binding Status}" TextColor="#475569" FontSize="12" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </Border>
    </Grid>

    <controls:BottomNavBar Grid.Row="1" CurrentRoute="games" />
    </Grid>
</ContentPage>
