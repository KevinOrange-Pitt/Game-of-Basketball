<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.Controls.BottomNavBar">

    <Border BackgroundColor="#0F172A"
            Padding="6,8"
            Stroke="#1E293B"
            StrokeThickness="1">
        <Grid ColumnDefinitions="*,*,*,*,*,*" ColumnSpacing="4">
            <Button x:Name="HomeButton" Grid.Column="0" Text="Home" Clicked="OnHomeClicked" FontSize="11" Padding="4,6" CornerRadius="8" />
            <Button x:Name="LiveButton" Grid.Column="1" Text="Live" Clicked="OnLiveClicked" FontSize="11" Padding="4,6" CornerRadius="8" />
            <Button x:Name="GamesButton" Grid.Column="2" Text="Games" Clicked="OnGamesClicked" FontSize="11" Padding="4,6" CornerRadius="8" />
            <Button x:Name="TeamsButton" Grid.Column="3" Text="Teams" Clicked="OnTeamsClicked" FontSize="11" Padding="4,6" CornerRadius="8" />
            <Button x:Name="PlayersButton" Grid.Column="4" Text="Players" Clicked="OnPlayersClicked" FontSize="11" Padding="4,6" CornerRadius="8" />
            <Button x:Name="StatsButton" Grid.Column="5" Text="Stats" Clicked="OnStatsClicked" FontSize="11" Padding="4,6" CornerRadius="8" />
        </Grid>
    </Border>
</ContentView>
